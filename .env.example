# OpenAI API key (required for Translate, Interview, Whisper, TTS, JD summarize, session notes)
OPENAI_API_KEY=sk-...

# NextAuth (required for Sign in with Google)
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
# In Google Cloud Console: create OAuth 2.0 credentials, add redirect URI:
# http://localhost:3000/api/auth/callback/google (dev) and your production URL

# Postgres with pgvector (for long-term memory, session_insights, dynamic prompt)
# Use POSTGRES_URL or DATABASE_URL. Run docs/schema-memory.sql in your DB first.
# Run docs/schema-analytics.sql for analytics_events table.
POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require

# Analytics (optional; consent-gated in UI)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
