# OpenAI API key (required for Translate, Interview, Whisper, TTS, JD summarize, session notes)
OPENAI_API_KEY=sk-...

# NextAuth (required for Sign in with Google)
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
# In Google Cloud Console: create OAuth 2.0 credentials, add redirect URI:
# http://localhost:3000/api/auth/callback/google (dev) and your production URL
